# =========================================
# WaBro V2 — Environment Variables
# Copy to .env and fill in values
# =========================================

# --- Server ---
PORT=8000
TZ=Asia/Kolkata

# --- Supabase (self-hosted DB) ---
# Uncomment if running Supabase locally
# DB_PASSWORD=your_secure_password_here

# --- Domain ---
APP_DOMAIN=wabro.propai.live

# --- SSL (Let's Encrypt) ---
SSL_EMAIL=vishal@chaoscraftlabs.com

# --- GitHub (for Coolify auto-deploy) ---
GIT_REPO=git@github.com:vishalgojha/wabro.git
GIT_BRANCH=main

# --- Monitoring ---
LOG_LEVEL=info
LOG_RETENTION_DAYS=14
