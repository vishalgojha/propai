{
  "name": "propai-web",
  "build": {
    "type": "dockerfile",
    "dockerfile": "apps/app/Dockerfile",
    "context": "."
  },
  "environment": {
    "NEXT_PUBLIC_SUPABASE_URL": "variable",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "variable",
    "API_PUBLIC_URL": "https://api.propai.live"
  },
  "network": "propai-network",
  "healthcheck": {
    "path": "/health",
    "port": 3000
  }
}
