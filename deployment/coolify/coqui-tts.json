{
  "name": "propai-tts",
  "image": "ghcr.io/coqui-ai/tts-cpu",
  "environment": {
    "COQUI_TTS_URL": "http://coqui-tts:5002"
  },
  "volumes": [
    "/root/.local/share/tts:/root/.local/share/tts"
  ],
  "network": "propai-network",
  "ports": [
    "5002:5002"
  ],
  "command": "python3 TTS/server/server.py --model_name tts_models/en/vctk/vits --port 5002",
  "restart": "unless-stopped"
}
