{
  "name": "propai-api",
  "build": {
    "type": "dockerfile",
    "dockerfile": "apps/api/Dockerfile",
    "context": "/"
  },
  "environment": {
    "PORT": "3001",
    "OLLAMA_BASE_URL": "http://ollama:11434",
    "CAMOFOX_URL": "http://camofox-browser:9377",
    "CAMOFOX_ALLOWED_HOSTS": "variable",
    "SUPABASE_URL": "variable",
    "SUPABASE_ANON_KEY": "variable",
    "SUPABASE_SERVICE_ROLE_KEY": "variable"
  },
  "network": "propai-network",
  "healthcheck": {
    "path": "/health",
    "port": 3001
  }
}
