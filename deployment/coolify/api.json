{
  "name": "propai-api",
  "build": {
    "type": "dockerfile",
    "dockerfile": "apps/api/Dockerfile",
    "context": "."
  },
    "environment": {
    "PORT": "3001",
    "ENABLE_SYSTEM_WHATSAPP_SESSION": "false",
    "GOOGLE_MODEL": "gemini-2.5-flash",
    "GROQ_BASE_URL": "https://api.groq.com/openai/v1",
    "GROQ_MODEL": "llama3-8b-8192",
    "OPENROUTER_BASE_URL": "https://openrouter.ai/api/v1",
    "OPENROUTER_MODEL": "openai/gpt-4o-mini",
    "DOUBLEWORD_BASE_URL": "https://api.doubleword.ai/v1",
    "DOUBLEWORD_MODEL": "qwen3-235b",
    "SUPABASE_URL": "variable",
    "SUPABASE_ANON_KEY": "variable",
    "SUPABASE_SERVICE_ROLE_KEY": "variable"
  },
  "network": "propai-network",
  "healthcheck": {
    "path": "/health",
    "port": 3001
  }
}
